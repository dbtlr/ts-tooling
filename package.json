{
  "name": "@dbtlr/tooling",
  "version": "0.0.0",
  "private": true,
  "description": "Tree-shakeable shared TypeScript, Oxlint, Vitest, Vite, and Vite+ config helpers for dbtlr projects.",
  "license": "MIT",
  "files": [
    "dist",
    "tsconfig",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./oxlint": {
      "types": "./dist/oxlint.d.mts",
      "default": "./dist/oxlint.mjs"
    },
    "./vitest": {
      "types": "./dist/vitest.d.mts",
      "default": "./dist/vitest.mjs"
    },
    "./vite-plus": {
      "types": "./dist/vite-plus.d.mts",
      "default": "./dist/vite-plus.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    },
    "./package-json": {
      "types": "./dist/package-json.d.mts",
      "default": "./dist/package-json.mjs"
    },
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/bun.json": "./tsconfig/bun.json",
    "./tsconfig/react.json": "./tsconfig/react.json",
    "./tsconfig/monorepo.json": "./tsconfig/monorepo.json",
    "./tsconfig/vitest.json": "./tsconfig/vitest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "format": "vp fmt",
    "fmt:check": "vp fmt --check",
    "test": "vp test",
    "check": "vp check && vp test && vp pack",
    "pack:dry": "pnpm pack --dry-run",
    "prepare": "vp config --no-agent"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite-plus": "^0.2.1"
  },
  "peerDependencies": {
    "vite": ">=7.0.0",
    "vite-plus": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "vite-plus": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.0.0"
}
