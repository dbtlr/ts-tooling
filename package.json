{
  "name": "@dbtlr/tooling",
  "version": "0.4.0",
  "description": "Shared TypeScript, Vitest, and Vite+ config for dbtlr projects — a toolingConfig() plugin plus à la carte concern helpers.",
  "homepage": "https://github.com/dbtlr/ts-tooling#readme",
  "bugs": "https://github.com/dbtlr/ts-tooling/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbtlr/ts-tooling.git"
  },
  "files": [
    "dist",
    "tsconfig",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./setup/dom": {
      "types": "./dist/setup/dom.d.mts",
      "default": "./dist/setup/dom.mjs"
    },
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/bun.json": "./tsconfig/bun.json",
    "./tsconfig/react.json": "./tsconfig/react.json",
    "./tsconfig/monorepo.json": "./tsconfig/monorepo.json",
    "./tsconfig/vitest.json": "./tsconfig/vitest.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "format": "vp fmt",
    "fmt:check": "vp fmt --check",
    "test": "vp test",
    "check": "vp check && vp test && vp pack",
    "check:examples": "bash scripts/check-examples.sh",
    "pack:dry": "pnpm pack --dry-run",
    "prepare": "vp config --no-agent",
    "prepack": "vp pack"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "^8.1.0",
    "vite-plus": "^0.2.1"
  },
  "peerDependencies": {
    "@testing-library/jest-dom": ">=6",
    "vite": ">=8.0.0",
    "vite-plus": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@testing-library/jest-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vite-plus": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
